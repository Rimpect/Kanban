// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Board{
    id      String       @id @default(uuid())
    columns Column[] 
    name    String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

}

model Column{
    id String @id @default(uuid())
    boardId String // Внешний ключ (подсмотрел)       
    name    String
    cards   Card[]   // Связь: у колонки много карточек (подсмотрел)
    position Float
    board   Board  @relation(fields: [boardId], references: [id],onDelete: Cascade)
    @@index([boardId])
}

model Card {
    id      String       @id @default(uuid())
    columnId String // Внешний ключ (подсмотрел), поменял на str из за строки ниже что бы типы совпадали
    column   Column   @relation(fields: [columnId], references: [id], onDelete: Cascade)//(подсмотрел)
    title    String   
    text String
    position Float   // Порядок карточки в колонке тоже подглядел
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    tags CardTag[]  
    @@index([columnId])
}
model CardTag {
    cardId String
    tagId String
    card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)
    tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)
    @@id([cardId, tagId])
}
model Tag {
    id String @id @default(uuid())
    name String @unique
    color String?
    cards CardTag[]
}
